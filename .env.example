# ── SaintSal Labs Platform — Environment Variables ──────────────────────────
# Copy to .env and fill in real values before running.

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ── AI Providers ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...
XAI_API_KEY=xai-...
PPLX_API_KEY=pplx-...          # Perplexity Sonar

# ── Payments ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...      # Monthly Pro plan price ID
STRIPE_PRICE_ELITE=price_...    # Monthly Elite plan price ID

# ── Real Estate APIs ──────────────────────────────────────────────────────────
RENTCAST_API_KEY=               # rentcast.io — property search, AVM, market data
PROPERTY_API_KEY=papi_...       # propertyapi.co — distressed, foreclosures, tax liens
ZILLOW_API_KEY=                 # RapidAPI key for Zillow Zestimate (optional supplementary)
GOOGLE_MAPS_KEY=                # Google Maps (optional)

# ── Social Media — LinkedIn ───────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=             # LinkedIn App Client ID
LINKEDIN_CLIENT_SECRET=         # LinkedIn App Client Secret
LINKEDIN_ACCESS_TOKEN=          # Optional: pre-authorized long-lived token

# ── Social Media — X / Twitter ────────────────────────────────────────────────
TWITTER_CLIENT_ID=              # Twitter App OAuth 2.0 Client ID
TWITTER_CLIENT_SECRET=          # Twitter App OAuth 2.0 Client Secret
TWITTER_API_KEY=                # Twitter API Key (for OAuth 1.0a signing)
TWITTER_API_SECRET=             # Twitter API Secret
TWITTER_ACCESS_TOKEN=           # OAuth 1.0a Access Token
TWITTER_ACCESS_SECRET=          # OAuth 1.0a Access Secret

# ── Social Media — Meta (Facebook + Instagram) ────────────────────────────────
FACEBOOK_APP_ID=                # Meta App ID (from developers.facebook.com)
FACEBOOK_APP_SECRET=            # Meta App Secret
FACEBOOK_PAGE_TOKEN=            # Page Access Token for posting to Facebook Page
FACEBOOK_PAGE_ID=               # Facebook Page ID
INSTAGRAM_APP_ID=               # Same as FACEBOOK_APP_ID for Instagram Basic Display
INSTAGRAM_APP_SECRET=           # Same as FACEBOOK_APP_SECRET
INSTAGRAM_ACCESS_TOKEN=         # Instagram Graph API token (via Meta Business)
INSTAGRAM_BUSINESS_ID=          # Instagram Business Account ID

# ── Social Media — Other Platforms ────────────────────────────────────────────
TIKTOK_CLIENT_KEY=              # TikTok for Developers App Key
TIKTOK_CLIENT_SECRET=           # TikTok for Developers App Secret
GOOGLE_CLIENT_ID=               # Google OAuth (YouTube publishing)
GOOGLE_CLIENT_SECRET=
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=
WHATSAPP_APP_ID=
WHATSAPP_APP_SECRET=
THREADS_APP_ID=
THREADS_APP_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ── Domain & GoDaddy ──────────────────────────────────────────────────────────
GODADDY_API_KEY=
GODADDY_API_SECRET=

# ── Business Formation (CorpNet) ──────────────────────────────────────────────
CORPNET_API_KEY=

# ── Web Search ────────────────────────────────────────────────────────────────
TAVILY_API_KEY=                 # tavily.com — web search

# ── App Config ────────────────────────────────────────────────────────────────
ENV=development                 # "production" to disable dev CORS origins
APP_URL=https://saintsallabs.com
PORT=8000
